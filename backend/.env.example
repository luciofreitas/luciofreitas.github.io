# Example backend .env (do NOT commit secrets)
# Copy to backend/.env and fill real values for deployment/local testing
#
# Notes:
# - Keep server-only secrets here (SERVICE_ROLE keys, DATABASE_URL). Do NOT
#   expose service role keys to the frontend.
# - For client-side keys (anon), define VITE_SUPABASE_ANON_KEY in the frontend
#   environment (see root .env.example) or inject at runtime.

DATABASE_URL=postgresql://username:password@localhost:5432/dbname
PGSSL=true
PGSSLMODE=require

# Public URL of this backend (optional)
RENDER_API_BASE=https://your-backend.example.com

# Supabase (server-only)
SUPABASE_URL=https://your-project.supabase.co
# Service role key (server-only, privileged). Keep secret. Set this in your
# deployment provider (Render) or in a local `.env` that is gitignored.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# PORT the backend listens on (default: 3001)
PORT=3001
