# Local Postgres used by docker-compose
DATABASE_URL=postgresql://parts:parts_pass@localhost:5432/partsdb

# Render / Production API base (optional)
# Set to the public URL of the deployed backend when using Render.
RENDER_API_BASE=

# Supabase configuration (server-only keys should never be exposed to browsers)
SUPABASE_URL=
# For server-side operations you can use the service role key. Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=

# If you also need client-side Supabase access from the frontend, set the anon
# key in the frontend environment (NOT here) or provide it via runtime injection.
SUPABASE_ANON_KEY=

# Notes:
# - Store real secrets in Render's Environment variables or in a local
#   `.env.local` that is gitignored. Do not commit secrets to the repo.
