## Local / shared environment variables
# Keep DATABASE_URL for local development or docker-compose setups
DATABASE_URL=postgresql://parts:parts_pass@localhost:5432/partsdb

# Render / Production API base
# If you deploy your backend to Render, set RENDER_API_BASE to the public
# URL (for example: https://your-service.onrender.com). The frontend can
# read this at runtime (or you can inject it into index.html at deploy time).
RENDER_API_BASE=

# Supabase configuration
# WARNING: never commit real keys to git. Use Render's dashboard secrets or
# your local environment to set these values.
# - SUPABASE_URL: the Supabase project REST/JS URL (ex: https://xyz.supabase.co)
# - SUPABASE_ANON_KEY: public anon key for client-side access
# - SUPABASE_SERVICE_ROLE_KEY: service role key (server-only; keep secret)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Notes:
# - For local development, you can create a `.env.local` (gitignored) to store
#   real secrets and use a dotenv loader in your app or backend to pick them up.
# - On Render, add these variables via the dashboard under Environment -> "Environment
#   Variables" (or via `render.yaml` / the CLI) so they are injected at runtime.
