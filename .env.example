# Database configuration (copy to .env and fill with real values)
# Example placeholder — replace with your local or production DB URL.
DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# Optional: Backend port
PORT=3001

# Frontend (Vite) environment variables - these must start with VITE_
# Set these where you run the Vite build or in your CI/provider build settings
# Example placeholders (DO NOT commit real keys)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Optional: embed API base into the frontend at build time
VITE_API_BASE=https://your-backend.example.com
